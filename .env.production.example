APP_NAME="Sistema GYC"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://tudominio.cl

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_CL

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# --- Datos que entrega cPanel -> MySQL Databases ---
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=usuario_nombrebd
DB_USERNAME=usuario_nombreuser
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# --- Brevo SMTP (mismo que en local, solo recordar autorizar la IP del hosting) ---
MAIL_MAILER=smtp
MAIL_SCHEME=
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=tu_usuario@smtp-brevo.com
MAIL_PASSWORD=tu_clave_smtp_brevo
MAIL_FROM_ADDRESS="sistema@gycconfecciones.cl"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

WOOCOMMERCE_URL=https://tutienda.cl
WOOCOMMERCE_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
WOOCOMMERCE_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

MERCADOLIBRE_URL=https://api.mercadolibre.com
MERCADOLIBRE_TOKEN=
MERCADOLIBRE_REFRESH_TOKEN=
MERCADOLIBRE_USER_ID=

MERCADOLIBRE_CLIENT_ID=
MERCADOLIBRE_CLIENT_SECRET=
MERCADOLIBRE_REDIRECT_URI=https://tudominio.cl/ml/callback
